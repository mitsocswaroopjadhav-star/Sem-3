class Book:
    def __init__(self, title, author, availability=True):
        self.title = title
        self.author = author
        self.availability = availability


class Patron:
    def __init__(self, name, patronid):
        self.name = name
        self.patronid = patronid


class Library:
    def __init__(self):
        self.books = []
        self.patrons = []

    def add_book(self, book):
        self.books.append(book)
        print(f"{book.title} was added to the library.")

    def register(self, patron):
        self.patrons.append(patron)
        print(f"{patron.name}   is registered.")

    def borrow(self, patron, book):
        if book.availability:
            book.availability = False
            print(f"{book.title} it  is issued by {patron.name}.")
        else:
            print(f"{book.title} it  is not available.")

    def return_book(self, patron, book):
        book.availability = True
        print(f"{book.title} is returned by {patron.name}.")


book1 = Book("Python Programming", "Guido van Rossum")
patron1 = Patron("Rahul", 101)

library = Library()

library.add_book(book1)
library.register(patron1)
library.borrow(patron1, book1)
library.return_book(patron1, book1)
      



