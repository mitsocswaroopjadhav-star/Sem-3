class Car:
    def __init__(self, name):
        self.name = name

    def show(self):
        print("Car name is", self.name)


class Owner:
    def __init__(self, name, car):
        self.name = name
        self.car = car

    def show(self):
        print(f"{self.name} owns {self.car}")


c = Car("BMW")
c.show()

o = Owner("Rahul", "BMW")
o.show()
